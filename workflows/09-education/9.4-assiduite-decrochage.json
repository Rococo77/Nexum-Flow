            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Décrochage détecté ?": {
      "main": [
        [
          {
            "node": "Message d'accompagnement IA",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Message d'accompagnement IA": {
      "main": [
        [
          {
            "node": "Email accompagnement étudiant",
            "type": "main",
            "index": 0
          },
          {
            "node": "Alerte responsable pédagogique",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,

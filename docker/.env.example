# ============================================================
# NEXUM FLOW - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Domaines
N8N_HOST=n8n.votre-domaine.fr
API_HOST=api.votre-domaine.fr
MINIO_HOST=files.votre-domaine.fr

# PostgreSQL
POSTGRES_DB=nexum_flow
POSTGRES_USER=nexum_user
POSTGRES_PASSWORD=CHANGEZ_MOI_postgres_password

# Redis
REDIS_PASSWORD=CHANGEZ_MOI_redis_password

# n8n
N8N_ENCRYPTION_KEY=CHANGEZ_MOI_32_caracteres_minimum
N8N_JWT_SECRET=CHANGEZ_MOI_jwt_secret_long

# SMTP (pour les notifications n8n)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_app
SMTP_SENDER=Nexum Flow <votre@email.com>

# MinIO (stockage de fichiers)
MINIO_ROOT_USER=nexum_admin
MINIO_ROOT_PASSWORD=CHANGEZ_MOI_minio_password

# OpenAI (conservé uniquement pour la transcription Whisper dans 5.2)
OPENAI_API_KEY=sk-...

# Mistral AI – utilisé par tous les workflows IA (créer une credential "OpenAI" dans n8n
# avec Base URL = https://api.mistral.ai/v1 et cette clé)
MISTRAL_API_KEY=

# Ollama (IA locale, optionnel)
OLLAMA_HOST=http://ollama:11434

# FastAPI
API_SECRET_KEY=CHANGEZ_MOI_api_secret_key

# CRM (adaptez selon votre CRM)
CRM_API_URL=https://votre-crm.com/api
CRM_API_KEY=votre_cle_api_crm

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft 365 (optionnel)
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_TENANT_ID=

# Facturation
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google (Maps, Places, Drive)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACE_ID=ChIJ...
GOOGLE_CALENDAR_ID=primary
GDRIVE_CLIENTS_FOLDER_ID=

# Trustpilot
TRUSTPILOT_API_KEY=
TRUSTPILOT_DOMAIN=votre-domaine.com

# WordPress (génération SEO)
WORDPRESS_URL=https://votre-site.com
WORDPRESS_USER=admin
WORDPRESS_PASSWORD=mot_de_passe_application

# Entreprise
COMPANY_DOMAIN=votre-domaine.fr

# Discord – IDs de canaux (récupérables via Mode développeur Discord)
DISCORD_LEADS_CHANNEL_ID=
DISCORD_COMMERCIAL_CHANNEL_ID=
DISCORD_CLIENTS_CHANNEL_ID=
DISCORD_ADMIN_CHANNEL_ID=
DISCORD_DIRECTION_CHANNEL_ID=
DISCORD_MARKETING_CHANNEL_ID=
DISCORD_REUNIONS_CHANNEL_ID=
DISCORD_RH_CHANNEL_ID=
DISCORD_SAV_CHANNEL_ID=
DISCORD_URGENT_CHANNEL_ID=
DISCORD_VEILLE_CHANNEL_ID=
DISCORD_GENERAL_CHANNEL_ID=

# Veille concurrentielle (JSON array des URLs)
CONCURRENTS_URLS=["https://concurrent1.fr","https://concurrent2.fr"]

# n8n API (pour le script d'import – générer dans n8n > Settings > API)
N8N_API_KEY=

# Traefik Dashboard (générer avec : htpasswd -nb admin motdepasse)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_HTPASSWD=admin:$$apr1$$...

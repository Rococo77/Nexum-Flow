        400
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "decision-admission",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0022-0022-0022-000000000002",
      "name": "Récupérer candidat",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [
        470,
        400
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, nom, prenom, email, formation_visee FROM candidatures WHERE id = $1",
        "additionalFields": {
          "queryParams": "={{ [$json.body.candidature_id || $json.candidature_id] }}"
        },
        "options": {}
      }
    },
    {
      "id": "a1b2c3d4-0022-0022-0022-000000000003",
      "name": "Préparer décision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        400
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const cand = $input.item.json;\nconst body = $('Webhook Décision').item.json.body || $('Webhook Décision').item.json;\nconst decision = (body.decision || '').toLowerCase();\nconst valides = ['admis', 'entretien', 'liste_attente', 'refuse'];\nif (!valides.includes(decision)) throw new Error('Décision invalide : ' + decision);\nreturn { ...cand, decision, date_entretien: body.date_entretien || null };"
      }
    },
    {
      "id": "a1b2c3d4-0022-0022-0022-000000000004",
      "name": "Admis ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        910,
        400
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "c",
              "leftValue": "={{ $json.decision }}",
              "rightValue": "admis",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "a1b2c3d4-0022-0022-0022-000000000005",
      "name": "Générer attestation PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1140,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.API_HOST }}/api/v1/documents/attestation/pdf",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "data",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      }
    },
    {
      "id": "a1b2c3d4-0022-0022-0022-000000000006",
      "name": "Email admission",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [
        1370,
        200
      ],
      "parameters": {
        "operation": "send",
        "toList": "={{ $('Préparer décision').item.json.email }}",
        "subject": "Félicitations – Vous êtes admis(e) en {{ $('Préparer décision').item.json.formation_visee }}",
        "emailType": "html",
        "message": "<html><body><p>Bonjour {{ $('Préparer décision').item.json.prenom }},</p><p>Nous avons le plaisir de vous informer que votre candidature pour la formation <strong>{{ $('Préparer décision').item.json.formation_visee }}</strong> a été <strong>retenue</strong>.</p><p>Vous trouverez ci-joint votre attestation d'admission. Les modalités d'inscription vous seront communiquées prochainement.</p><p>Félicitations et bienvenue !</p><p>Le service des admissions</p></body></html>",
        "attachmentsUi": {
          "attachmentsBinary": [
            {
              "property": "data"
            }
          ]
        }
      }
    },
    {

            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  },
  "versionId": "a1b2c3d4-0020-0020-0020-000000000099",
  "meta": {
    "instanceId": "nexum-flow"
  },
  "tags": [

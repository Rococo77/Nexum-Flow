        "emailType": "html",
        "message": "<html><body><p>Bonjour {{ $('Préparer décision').item.json.prenom }},</p><p>Suite à l'étude de votre dossier pour <strong>{{ $('Préparer décision').item.json.formation_visee }}</strong>, nous souhaitons vous rencontrer lors d'un entretien d'admission.</p><p><strong>Date proposée : {{ $('Préparer décision').item.json.date_entretien }}</strong></p><p>Merci de confirmer votre disponibilité en répondant à cet email.</p><p>Cordialement,<br>Le service des admissions</p></body></html>"
      }
